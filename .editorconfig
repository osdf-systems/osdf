# EditorConfig: consistent formatting across editors.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.rs]
indent_size = 4

[*.{md,yml,yaml}]
trim_trailing_whitespace = false

[*.ps1]
end_of_line = crlf

[Makefile]
indent_style = tab
